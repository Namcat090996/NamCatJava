package vn.com.namcat.cautruclaptrinh;

import java.util.Scanner;

/**
 * 
 */
public class BaiTapCauTrucLapTrinhJava02 {

	/**
	 * @param args
	 */
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		//Declare an object that allows for retrieving information from the keyboard.
		
		Scanner sc = new Scanner(System.in);
		
		//Bài tập 11:
		
		//Khai báo biến
		
		double r = 0, canhDCN = 0, canhRCN = 0, canhV = 0, dientichT = 0, chuviT = 0, dientichCN = 0, chuviCN = 0, dientichV = 0, chuviV = 0;
		
		//Khai báo hằng số PI
		
		final double PI = 3.14;
		
		//Nhập thông số bán kính, cạnh
		
		r = sc.nextDouble();
		
		canhDCN = sc.nextDouble();
		
		canhRCN = sc.nextDouble();
		
		canhV = sc.nextDouble();

		//Tính toán
		
		dientichT = PI*Math.pow(r, 2);	dientichCN = canhDCN * canhRCN;	dientichV = Math.pow(canhV, 2);
		
		chuviT = 2*PI*r;	chuviCN = (canhDCN + canhRCN)*2;	chuviV = 4*canhV;
		
		
		
	}

}
